generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  EMPLOYEE
  ADMIN
  HR
}

enum Status {
  ACTIVE
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

enum LeaveType {
  PAID
  SICK
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id              String           @id @default(uuid())
  employeeId      String           @unique
  email           String           @unique
  passwordHash    String
  displayName     String
  role            Role             @default(EMPLOYEE)
  status          Status           @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  profile         EmployeeProfile?
  attendance      Attendance[]
  leaveRequests   LeaveRequest[]   @relation("EmployeeLeaves")
  approvedLeaves  LeaveRequest[]   @relation("AdminApprovedLeaves")
  payroll         Payroll[]
}

model EmployeeProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id])
  phone             String?
  address           String?
  profilePictureUrl String?
  department        String?
  designation       String?
  joinDate          DateTime? @db.Date
  baseSalary        Float?
}

model Attendance {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  date         DateTime         @db.Date
  checkInTime  DateTime
  checkOutTime DateTime?
  status       AttendanceStatus
}

model LeaveRequest {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation("EmployeeLeaves", fields: [userId], references: [id])
  leaveType      LeaveType
  startDate      DateTime     @db.Date
  endDate        DateTime     @db.Date
  remarks        String?
  status         LeaveStatus  @default(PENDING)
  approvedById   String?
  approvedBy     User?        @relation("AdminApprovedLeaves", fields: [approvedById], references: [id])
  adminComments  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Payroll {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  month       Int
  year        Int
  baseSalary  Float
  deductions  Float    @default(0)
  netSalary   Float
  isPaid      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
